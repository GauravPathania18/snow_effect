{
  "name": "ui-effects",
  "version": "1.0.0",
  "description": "A lightweight, high-performance JavaScript library that adds realistic snow animations to any web page. Features adaptive wind modes, snow accumulation physics, and intelligent color detection.",
  "main": "dist/ui-effects.min.js",
  "repository": {
    "type": "git",
    "url": ""
  },
  "scripts": {
    "start": "npm run build && npx http-server . -c-1 -p 3000 -o public/index.html",
    "test": "node tests/smoke.test.js",
    "build": "esbuild src/index.js --bundle --minify --sourcemap --format=iife --global-name=UIEffects --outfile=dist/ui-effects.min.js",
    "build:dev": "esbuild src/index.js --bundle --format=iife --global-name=UIEffects --outfile=dist/ui-effects.js",
    "watch": "esbuild src/index.js --bundle --format=iife --global-name=UIEffects --outfile=dist/ui-effects.js --watch"
  },
  "keywords": [
    "snow",
    "animation",
    "effects",
    "ui",
    "particles",
    "canvas"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "esbuild": "^0.27.2"
  }
}
